# === Required ===
DOMAIN=example.com
# Server IP (auto-detected if empty)
SERVER_IP=

# === NPMplus Admin ===
NPM_ADMIN_EMAIL=admin@example.com
NPM_ADMIN_PASSWORD=ChangeMe!Str0ng

# === CrowdSec ===
# Auto-generated by setup.sh if empty
CROWDSEC_BOUNCER_KEY=

# === Mailcow Toolkit ===
# Auto-generated by setup.sh if empty
MAILCOW_API_KEY=
TOOLKIT_SECRET_KEY=

# === Storage ===
# Optional: bind mailcow's vmail volume to a host path (e.g. a mergerfs pool).
# Leave empty to use the default Docker named volume (under /var/lib/docker).
VMAIL_DEVICE=
